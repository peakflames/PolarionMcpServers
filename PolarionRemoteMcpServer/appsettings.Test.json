{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "PolarionMcpServers": "Debug"
    }
  },
  "TestLogging": {
    "LogDirectory": "logs/test-runs",
    "RetainCount": 10,
    "OutputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
  }
}
